{
  "name": "tgd-review-agent",
  "version": "0.1.0",
  "description": "CLI agent that reviews GitHub/GitLab pull requests using the pi SDK, dispatching configurable rule-based review tasks and posting a synthesized PR comment.",
  "type": "module",
  "bin": {
    "tgd-review-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src test"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@juicesharp/rpiv-advisor": "1.20.0",
    "gray-matter": "4.0.3",
    "pi-subagents": "0.34.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.0.0"
  }
}
